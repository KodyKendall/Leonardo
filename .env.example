# Necessary:
LLAMABOT_API_URL="http://llamabot:8000"
LLAMABOT_WEBSOCKET_URL="ws://llamabot:8000/ws"
REDIS_URL="redis://redis:6379/1"
LLAMAPRESS_API_URL="http://llamapress:3000"

# Only necessary for production if you want to attach files in AWS s3 (highly recommended)
AWS_KEY='your-access-key'
AWS_PASS='your-secret-key'
AWS_BUCKET='your-bucket-name'
AWS_REGION='your-region'

OPENAI_API_KEY=sk-proj-xx
ANTHROPIC_API_KEY=sk-anti-api03-xx
TAVILY_API_KEY=tvly-dev-xx

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="lsv2_pt"
LANGSMITH_PROJECT=""

POSTGRES_PASSWORD=password

# PostgreSQL database for user authentication and LangGraph checkpoints
# By default, checkpointer uses AUTH_DB_URI (llamabot_production)
# This consolidates all LlamaBot data in one place
AUTH_DB_URI="postgresql://postgres:password@db:5432/llamabot_production"

# (Legacy) Old DB_URI for Rails app - checkpointer falls back to this if AUTH_DB_URI not set
DB_URI="postgresql://postgres:password@db:5432/llamapress_development"

# (Optional) Override checkpointer database if you want it separate
# Falls back to: CHECKPOINTER_DB_URI -> LEONARDO_DB_URI -> AUTH_DB_URI -> DB_URI
CHECKPOINTER_DB_URI=

# Checkpoint cleanup: threads inactive for this long get cleaned up
# (Protects active users recovering from errors)
CHECKPOINT_STALE_MINUTES=30

SECRET_KEY_BASE=xxx

# If you want Leonardo to join meetings to capture context
RECALL_SECRET_API_KEY=whsec_xxx
RECALL_API_KEY=xxx

WS_AUTH_REQUIRED=true
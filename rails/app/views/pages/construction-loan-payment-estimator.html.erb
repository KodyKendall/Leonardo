    <!-- FAQ Section -->
    <section class="mt-32">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Common Questions on Construction Finance</h2>
        <p class="text-base-content/60 text-lg">Essential insights for professional developers and builders.</p>

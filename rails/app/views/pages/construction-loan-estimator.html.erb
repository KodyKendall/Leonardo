<div class="max-w-4xl mx-auto px-4 py-12">
  <article class="prose prose-lg max-w-none prose-headings:font-black prose-headings:tracking-tight prose-p:text-gray-600 prose-p:leading-relaxed">
    <header class="mb-16">

<%= form_with model: contact_submission, id: "contact_form_container", class: "max-w-xl mx-auto text-left", data: { turbo_stream: true } do |f| %>
  <% if contact_submission.errors.any? %>
    <div class="alert alert-error mb-6 rounded-2xl shadow-sm border-none bg-red-50 text-red-700">
      <div class="flex flex-col items-start gap-1">
        <div class="flex items-center gap-2 font-bold">
          <i class="fas fa-exclamation-circle"></i>
          <span>Please fix the following errors:</span>
        </div>
        <ul class="text-sm list-disc list-inside opacity-90">
          <% contact_submission.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div class="form-control w-full">
      <%= f.label :first_name, class: "label px-1" do %>
        <span class="label-text font-semibold text-brand-purple">First Name</span>
      <% end %>
      <%= f.text_field :first_name, placeholder: "John", class: "input input-bordered w-full rounded-xl focus:border-brand-purple focus:ring-brand-purple/20 bg-white/50" %>
    </div>

    <div class="form-control w-full">
      <%= f.label :last_name, class: "label px-1" do %>
        <span class="label-text font-semibold text-brand-purple">Last Name</span>
      <% end %>
      <%= f.text_field :last_name, placeholder: "Doe", class: "input input-bordered w-full rounded-xl focus:border-brand-purple focus:ring-brand-purple/20 bg-white/50" %>
    </div>
  </div>

  <div class="form-control mb-4">
    <%= f.label :company_name, class: "label px-1" do %>
      <span class="label-text font-semibold text-brand-purple">Company Name</span>
    <% end %>
    <%= f.text_field :company_name, placeholder: "Acme Corp", class: "input input-bordered w-full rounded-xl focus:border-brand-purple focus:ring-brand-purple/20 bg-white/50" %>
  </div>

  <div class="form-control mb-4">
    <%= f.label :title, class: "label px-1" do %>
      <span class="label-text font-semibold text-brand-purple">Job Title</span>
    <% end %>
    <%= f.text_field :title, placeholder: "Estimator", class: "input input-bordered w-full rounded-xl focus:border-brand-purple focus:ring-brand-purple/20 bg-white/50" %>
  </div>

  <div class="form-control mb-8">
    <%= f.label :email, class: "label px-1" do %>
      <span class="label-text font-semibold text-brand-purple">Work Email</span>
    <% end %>
    <%= f.email_field :email, placeholder: "john@acme.com", class: "input input-bordered w-full rounded-xl focus:border-brand-purple focus:ring-brand-purple/20 bg-white/50" %>
  </div>

  <div class="form-control mb-8">
    <%= f.label :attachment, class: "label px-1" do %>
      <div class="flex flex-col">
        <span class="label-text font-semibold text-brand-purple">Upload your spreadsheet (optional)</span>
        <span class="label-text-alt text-gray-400 italic">Submit an Excel or CSV for analysis</span>
      </div>
    <% end %>
    <%= f.file_field :attachment, class: "file-input file-input-bordered file-input-primary w-full rounded-xl bg-white/50 focus:border-brand-purple focus:ring-brand-purple/20", accept: ".csv, .xlsx, .xls" %>
  </div>

  <div class="flex justify-center">
    <%= f.submit class: "btn btn-brand btn-lg w-full md:w-auto min-w-[200px] shadow-xl hover:scale-105 transition-transform" do %>
      <span>Get a Free Consultation</span>
      <i class="fas fa-arrow-right ml-2 text-sm"></i>
    <% end %>
  </div>
<% end %>

<% content_for :title, "Steel Estimating AI | AI Construction Steel Takeoff & Estimating Software" %>

<% content_for :hero_section do %>
  <div class="bg-brand-gradient relative overflow-hidden text-white">
    <!-- Background Blurs for depth -->
    <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-accent-purple/20 blur-[120px] rounded-full pointer-events-none opacity-50"></div>
    <div class="absolute bottom-0 right-1/4 w-[600px] h-[600px] bg-brand-blue/10 blur-[150px] rounded-full pointer-events-none opacity-50"></div>

    <% content_for :navbar_class, "bg-transparent shadow-none border-none" %>
    <% content_for :navbar_text_class, "text-white" %>
    <% content_for :navbar_logo, "https://llamapress-ai-image-uploads.s3.us-west-2.amazonaws.com/4bmqe5iolvp84ceyk9ttz8vylrym" %>
    <% content_for :navbar_button_class, "bg-white !text-brand-purple hover:bg-gray-100 border-none shadow-xl" %>
    <%= render 'shared/navbar' %>

    <div class="relative z-10 px-8 py-20 md:py-32 flex flex-col items-center text-center max-w-7xl mx-auto">
      <div class="badge-brand mb-8 flex items-center gap-2 ring-4 ring-white/10">
        <i class="fas fa-wand-magic-sparkles"></i>
        <span>The New Standard for Steel</span>
      </div>
      
      <h1 class="text-5xl md:text-8xl font-black mb-8 leading-tight max-w-5xl tracking-tight">
        Bid <span class="text-brand-blue">6x More Jobs</span> with AI Precision
      </h1>
      
      <p class="text-xl md:text-2xl text-white/80 mb-12 max-w-3xl font-light leading-relaxed">
        The ultimate custom system for construction companies transitioning from fragile spreadsheets to high-velocity estimating software.
      </p>

      <div class="flex flex-wrap gap-6 justify-center">
        <%= link_to new_user_registration_path, class: "bg-white text-brand-purple rounded-full px-10 py-4 font-bold hover:shadow-2xl hover:shadow-white/20 transition-all flex items-center gap-3 text-lg" do %>
          <span>Get Started Free</span>
          <i class="fas fa-arrow-right"></i>
        <% end %>
        <div class="glass-dark rounded-full px-10 py-4 font-bold flex items-center gap-3 cursor-pointer hover:bg-white/10 transition-all border-white/20 text-lg">
          <i class="fas fa-play-circle text-brand-blue"></i>
          <span>Watch Demo</span>
        </div>
      </div>
    </div>
  </div>
<% end %>

<% content_for :full_width, true %>

<div class="bg-white min-h-screen">
  <!-- Comparison Section -->
  <div class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 overflow-hidden">
    <div class="text-center mb-20">
      <h2 class="text-5xl md:text-7xl font-black text-brand-purple mb-6 tracking-tight">Evolution of Estimating</h2>
      <p class="text-gray-500 text-xl max-w-3xl mx-auto font-light leading-relaxed">
        Stop wrestling with spreadsheets. We transform your manual processes into a high-velocity AI system.
      </p>
    </div>

    <div class="space-y-12">
      <!-- Phase 1: The Old Way -->
      <div class="rounded-[3rem] bg-gray-50 border border-gray-100 p-8 md:p-16 relative overflow-hidden group">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-20 items-center">
          <div class="lg:col-span-2 order-2 lg:order-1">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center text-red-500 text-xl shadow-inner">
                <i class="fas fa-times"></i>
              </div>
              <span class="text-xs font-extrabold uppercase tracking-[0.3em] text-gray-400">Phase 01: Legacy Workflow</span>
            </div>
            
            <h3 class="text-3xl md:text-4xl font-black text-brand-purple mb-6 leading-tight">The Excel Chaos</h3>
            <p class="text-gray-500 text-lg mb-8 font-light leading-relaxed">
              Fragile formulas, manual data entry, and version control nightmares. One wrong cell can ruin an entire bid.
            </p>
            
            <div class="glass-white p-6 rounded-2xl border border-gray-200 shadow-sm inline-block">
              <p class="text-gray-500 italic flex items-center gap-3">
                <i class="fas fa-quote-left text-red-300"></i>
                "We were spending 4 days just to get the quantities right. It was unsustainable."
              </p>
            </div>
          </div>

          <div class="lg:col-span-3 order-1 lg:order-2">
            <div class="rounded-[2rem] overflow-hidden border border-gray-200 shadow-2xl transition-all group-hover:scale-[1.02] duration-500 bg-white p-3">
              <img src="https://llamapress-ai-image-uploads.s3.us-west-2.amazonaws.com/esdmd9wkjkulczhgy9e7l77xemek" alt="Old Way: Spreadsheet Chaos" class="w-full h-auto rounded-2xl grayscale-[0.3] group-hover:grayscale-0 transition-all duration-700">
            </div>
          </div>
        </div>
      </div>

      <!-- Bridge -->
      <div class="flex flex-col items-center justify-center -my-6 relative z-10">
        <div class="w-20 h-20 rounded-full bg-brand-gradient flex items-center justify-center text-white shadow-2xl shadow-brand-purple/40 ring-8 ring-white">
          <i class="fas fa-rocket text-3xl"></i>
        </div>
        <div class="mt-4 badge-brand !text-xs !px-6 py-2 shadow-xl">The Transformation Loop (6 Weeks)</div>
      </div>

      <!-- Phase 2: The New Way -->
      <div class="rounded-[3rem] bg-[#2D2442] p-8 md:p-16 relative overflow-hidden group">
        <!-- Background Blurs -->
        <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-purple-500/20 blur-[100px] rounded-full pointer-events-none transition-all group-hover:bg-purple-500/30"></div>
        <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-brand-blue/10 blur-[80px] rounded-full pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-20 items-center relative z-10">
          <div class="lg:col-span-3">
            <div class="rounded-[2rem] overflow-hidden border border-white/10 shadow-purple-500/20 shadow-[0_0_50px_-12px_rgba(139,92,246,0.3)] transition-all group-hover:shadow-purple-500/40 group-hover:scale-[1.05] duration-500 bg-[#1e172e] p-3">
              <img src="https://llamapress-ai-image-uploads.s3.us-west-2.amazonaws.com/uxsgsdkjxlsss7e7cymnh93tn03x" alt="New Way: AI Powered Software" class="w-full h-auto rounded-2xl">
            </div>
          </div>

          <div class="lg:col-span-2">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-12 h-12 rounded-full bg-green-500/20 border border-green-500/30 flex items-center justify-center text-green-400 text-xl shadow-[0_0_20px_rgba(34,197,94,0.2)]">
                <i class="fas fa-check"></i>
              </div>
              <span class="text-xs font-extrabold uppercase tracking-[0.3em] text-white/40">Phase 02: AI High-Velocity</span>
              <div class="bg-green-500 text-white text-[10px] font-black px-4 py-1.5 rounded-full uppercase tracking-tighter shadow-lg shadow-green-500/40">62% Faster</div>
            </div>
            
            <h3 class="text-3xl md:text-5xl font-black text-white mb-6 leading-tight tracking-tight">The AI Engine</h3>
            <p class="text-white/60 text-lg mb-8 font-light leading-relaxed">
              Your existing logic, supercharged by AI. Instant quantities, live margin control, and 100% bid accuracy—built specifically for your team's unique workflow.
            </p>
            
            <div class="glass-dark p-6 rounded-2xl border border-white/10 shadow-2xl inline-block">
              <p class="text-white/80 italic font-medium flex items-center gap-3">
                <i class="fas fa-quote-left text-brand-blue/50"></i>
                "We now bid with 100% confidence in minutes, not days. The system is unshakeable."
              </p>
            </div>

            <div class="mt-12 flex flex-wrap gap-4">
              <div class="flex items-center gap-2 text-white/50 text-sm">
                <i class="fas fa-check-circle text-brand-blue"></i>
                <span>Multi-user Sync</span>
              </div>
              <div class="flex items-center gap-2 text-white/50 text-sm">
                <i class="fas fa-check-circle text-brand-blue"></i>
                <span>Automated Takeoffs</span>
              </div>
              <div class="flex items-center gap-2 text-white/50 text-sm">
                <i class="fas fa-check-circle text-brand-blue"></i>
                <span>Live Material Rates</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Benefits Section -->
  <div class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
        <div class="flex flex-col items-start">
          <div class="w-16 h-16 rounded-2xl bg-brand-purple flex items-center justify-center text-white text-2xl mb-8 shadow-lg shadow-brand-purple/20">
            <i class="fas fa-microchip"></i>
          </div>
          <h3 class="text-2xl font-black text-brand-purple mb-4 tracking-tight">AI Margin Control</h3>
          <p class="text-gray-500 leading-relaxed font-light">Stop guessing at your labor rates. Our AI identifies hidden costs and ensures every bid protects your bottom line.</p>
        </div>
        
        <div class="flex flex-col items-start">
          <div class="w-16 h-16 rounded-2xl bg-brand-blue flex items-center justify-center text-white text-2xl mb-8 shadow-lg shadow-brand-blue/20">
            <i class="fas fa-layer-group"></i>
          </div>
          <h3 class="text-2xl font-black text-brand-purple mb-4 tracking-tight">Workflow Sync</h3>
          <p class="text-gray-500 leading-relaxed font-light">Custom built around your existing shop logic. No generic templates—this is your system, accelerated by AI.</p>
        </div>

        <div class="flex flex-col items-start">
          <div class="w-16 h-16 rounded-2xl bg-accent-purple flex items-center justify-center text-white text-2xl mb-8 shadow-lg shadow-accent-purple/20">
            <i class="fas fa-shield-halved"></i>
          </div>
          <h3 class="text-2xl font-black text-brand-purple mb-4 tracking-tight">Key-Man Protection</h3>
          <p class="text-gray-500 leading-relaxed font-light">Institutionalize your estimating logic. If your head estimator is away, the business doesn't stop.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Insights Section -->
  <div id="recent-posts" class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center mb-16 gap-8 text-center md:text-left">
        <div>
          <h2 class="text-4xl md:text-6xl font-black text-brand-purple tracking-tight">Expert Insights</h2>
          <p class="text-gray-500 mt-4 text-lg">The latest in steel construction and AI estimating.</p>
        </div>
        <%= link_to static_page_path(slug: "blog"), class: "btn-brand" do %>
          View All Insights
        <% end %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        <% @posts.each do |slug| %>
          <%= link_to static_page_path(slug: slug), class: "group block" do %>
            <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm transition-all h-full flex flex-col hover:shadow-2xl hover:shadow-brand-purple/5 hover:-translate-y-2">
              <div class="badge-brand mb-6 self-start">Article</div>
              <h2 class="text-2xl font-black text-brand-purple mb-4 leading-tight group-hover:text-brand-blue transition-colors">
                <%= slug.titleize %>
              </h2>
              <p class="text-gray-500 font-light mb-8 line-clamp-3 flex-grow">
                Mastering the complexities of <%= slug.gsub("-", " ") %> and modernizing your bid process.
              </p>
              <div class="flex items-center gap-2 text-brand-purple font-bold">
                <span>Read Article</span>
                <i class="fas fa-arrow-right text-brand-blue group-hover:translate-x-2 transition-transform"></i>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

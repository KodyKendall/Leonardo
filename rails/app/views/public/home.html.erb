<% content_for :title, "Steel Estimating AI | AI Construction Steel Takeoff & Estimating Software" %>

<div class="bg-white min-h-screen">
  <!-- Hero Section (Founding Pilot Look) -->
  <div class="pt-8 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto founding-pilot rounded-[3xl] md:rounded-[5xl] shadow-2xl relative">
      <!-- Background Blurs for depth -->
      <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-accent-purple/20 blur-[100px] rounded-full pointer-events-none"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-brand-blue/10 blur-[120px] rounded-full pointer-events-none"></div>

      <div class="relative z-10 px-8 py-20 md:py-32 flex flex-col items-center text-center">
        <div class="badge-brand mb-8 flex items-center gap-2">
          <i class="fas fa-wand-magic-sparkles"></i>
          <span>The New Standard for Steel</span>
        </div>
        
        <h1 class="text-5xl md:text-8xl font-black mb-8 leading-tight max-w-5xl">
          Bid <span class="text-brand-blue">6x More Jobs</span> with AI Precision
        </h1>
        
        <p class="text-xl md:text-2xl text-white/70 mb-12 max-w-3xl font-light leading-relaxed">
          The ultimate custom system for construction companies transitioning from fragile spreadsheets to high-velocity estimating software.
        </p>

        <div class="flex flex-wrap gap-6 justify-center">
          <%= link_to new_user_registration_path, class: "btn-brand flex items-center gap-3" do %>
            <span>Get Started Free</span>
            <i class="fas fa-arrow-right"></i>
          <% end %>
          <div class="glass-dark rounded-full px-8 py-3 font-bold flex items-center gap-3">
            <i class="fas fa-play-circle text-brand-blue"></i>
            <span>Watch Demo</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Comparison Section -->
  <div class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-black text-brand-purple mb-4">Evolution of Estimating</h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">See how we transform your manual workflow into a streamlined AI engine.</p>
    </div>

    <div class="relative flex flex-col lg:flex-row items-center justify-center gap-12">
      <!-- Before Card -->
      <div class="w-full lg:w-1/3 group">
        <div class="bg-gray-50 rounded-4xl p-8 border border-gray-100 shadow-sm transition-all group-hover:shadow-xl">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-500">
              <i class="fas fa-times"></i>
            </div>
            <span class="text-sm font-extrabold uppercase tracking-widest text-gray-400">Old Way: Excel</span>
          </div>
          <div class="rounded-2xl overflow-hidden border border-gray-200 mb-6 bg-white p-2">
            <img src="https://llamapress-ai-image-uploads.s3.us-west-2.amazonaws.com/esdmd9wkjkulczhgy9e7l77xemek" alt="Before: Spreadsheet" class="w-full h-auto rounded-xl">
          </div>
          <p class="text-gray-500 text-sm italic">"One wrong formula ruined our entire bid."</p>
        </div>
      </div>

      <!-- Arrow -->
      <div class="hidden lg:flex flex-col items-center">
        <div class="w-16 h-16 rounded-full bg-brand-gradient flex items-center justify-center text-white shadow-xl ring-8 ring-brand-purple/5">
          <i class="fas fa-rocket text-2xl"></i>
        </div>
        <div class="mt-4 badge-brand">6 Weeks</div>
      </div>

      <!-- After Card -->
      <div class="w-full lg:w-3/5 group">
        <div class="bg-brand-purple/5 rounded-4xl p-8 border border-brand-purple/10 shadow-sm transition-all group-hover:shadow-2xl group-hover:shadow-brand-purple/10">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-green-600">
                <i class="fas fa-check"></i>
              </div>
              <span class="text-sm font-extrabold uppercase tracking-widest text-brand-purple">New Way: AI Takeoff</span>
            </div>
            <div class="bg-green-500 text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-tighter">62% Faster</div>
          </div>
          <div class="rounded-2xl overflow-hidden border-2 border-brand-purple/20 shadow-2xl bg-white p-2 mb-6">
            <img src="https://llamapress-ai-image-uploads.s3.us-west-2.amazonaws.com/uxsgsdkjxlsss7e7cymnh93tn03x" alt="After: Custom Software" class="w-full h-auto rounded-xl">
          </div>
          <p class="text-brand-purple font-medium">"We now bid with 100% confidence in minutes, not days."</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Benefits Section -->
  <div class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
        <div class="flex flex-col items-start">
          <div class="w-16 h-16 rounded-2xl bg-brand-purple flex items-center justify-center text-white text-2xl mb-8 shadow-lg shadow-brand-purple/20">
            <i class="fas fa-microchip"></i>
          </div>
          <h3 class="text-2xl font-black text-brand-purple mb-4 tracking-tight">AI Margin Control</h3>
          <p class="text-gray-500 leading-relaxed font-light">Stop guessing at your labor rates. Our AI identifies hidden costs and ensures every bid protects your bottom line.</p>
        </div>
        
        <div class="flex flex-col items-start">
          <div class="w-16 h-16 rounded-2xl bg-brand-blue flex items-center justify-center text-white text-2xl mb-8 shadow-lg shadow-brand-blue/20">
            <i class="fas fa-layer-group"></i>
          </div>
          <h3 class="text-2xl font-black text-brand-purple mb-4 tracking-tight">Workflow Sync</h3>
          <p class="text-gray-500 leading-relaxed font-light">Custom built around your existing shop logic. No generic templates—this is your system, accelerated by AI.</p>
        </div>

        <div class="flex flex-col items-start">
          <div class="w-16 h-16 rounded-2xl bg-accent-purple flex items-center justify-center text-white text-2xl mb-8 shadow-lg shadow-accent-purple/20">
            <i class="fas fa-shield-halved"></i>
          </div>
          <h3 class="text-2xl font-black text-brand-purple mb-4 tracking-tight">Key-Man Protection</h3>
          <p class="text-gray-500 leading-relaxed font-light">Institutionalize your estimating logic. If your head estimator is away, the business doesn't stop.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Insights Section -->
  <div id="recent-posts" class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center mb-16 gap-8 text-center md:text-left">
        <div>
          <h2 class="text-4xl md:text-6xl font-black text-brand-purple tracking-tight">Expert Insights</h2>
          <p class="text-gray-500 mt-4 text-lg">The latest in steel construction and AI estimating.</p>
        </div>
        <%= link_to "#", class: "btn-brand" do %>
          View All Insights
        <% end %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        <% @posts.each do |slug| %>
          <%= link_to static_page_path(slug: slug), class: "group block" do %>
            <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm transition-all h-full flex flex-col hover:shadow-2xl hover:shadow-brand-purple/5 hover:-translate-y-2">
              <div class="badge-brand mb-6 self-start">Article</div>
              <h2 class="text-2xl font-black text-brand-purple mb-4 leading-tight group-hover:text-brand-blue transition-colors">
                <%= slug.titleize %>
              </h2>
              <p class="text-gray-500 font-light mb-8 line-clamp-3 flex-grow">
                Mastering the complexities of <%= slug.gsub("-", " ") %> and modernizing your bid process.
              </p>
              <div class="flex items-center gap-2 text-brand-purple font-bold">
                <span>Read Article</span>
                <i class="fas fa-arrow-right text-brand-blue group-hover:translate-x-2 transition-transform"></i>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

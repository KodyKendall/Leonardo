<% content_for :title, "Steel Estimating AI | AI Construction Steel Takeoff & Estimating Software" %>

<div class="bg-base-100 min-h-screen">
  <!-- Hero Section -->
  <div class="hero min-h-[70vh] bg-base-200">
    <div class="hero-content text-center">
      <div class="flex flex-col items-center">
        <div class="max-w-2xl">
          <h2 class="text-xl md:text-2xl font-bold text-llama-blue mb-2">
            AI construction steel takeoff & estimating software
          </h2>
          <h1 class="text-5xl md:text-7xl font-black text-llama-dark mb-6 leading-tight">
            Save time & bid <span class="text-llama-blue">6x more jobs</span>
          </h1>
          <p class="py-4 text-xl text-gray-600 mb-8 font-light">
            Build perfect bids in minutes with a custom system built around your exact pricing logic, labor rates, and vendor pricing. Keeps everything synced so you bid consistently, fast, and right. It's like having a Jr. Estimator for perfect bid setup, without paying for one.
          </p>
        </div>

        <div class="w-full max-w-6xl mt-12 px-4">
          <div class="relative flex flex-col lg:flex-row items-center justify-center gap-8 lg:gap-0">

            <!-- Before Card -->
            <div class="relative z-10 lg:-mr-8 transform lg:-rotate-2 hover:rotate-0 transition-transform duration-300">
              <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-200">
                <!-- Card Header -->
                <div class="bg-gradient-to-r from-gray-100 to-gray-50 px-8 py-5 border-b border-gray-200 text-center">
                  <div class="flex items-center justify-center gap-3">
                    <i class="fas fa-times text-red-500 text-xl"></i>
                    <span class="text-lg font-bold text-gray-800 uppercase tracking-wide">Before: Excel Spreadsheet</span>
                  </div>
                </div>
                <!-- Image -->
                <div class="p-2 bg-gray-50">
                  <img src="https://llamapress-ai-image-uploads.s3.us-west-2.amazonaws.com/esdmd9wkjkulczhgy9e7l77xemek" alt="Before: Spreadsheet" class="w-full max-w-[480px] h-auto rounded-lg">
                </div>
                <!-- Card Footer -->
                <div class="px-6 py-3 bg-gray-50 border-t border-gray-100">
                  <div class="flex items-center gap-2 text-gray-500 text-sm">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span>Manual entry, error-prone</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Arrow Connector -->
            <div class="relative z-40 flex flex-col items-center lg:mx-4">
              <div class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white w-16 h-16 rounded-full flex items-center justify-center shadow-xl ring-4 ring-white">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
              </div>
              <span class="mt-2 text-xs font-bold text-indigo-600 uppercase tracking-widest bg-white px-3 py-1 rounded-full shadow-sm">6 Weeks</span>
            </div>

            <!-- After Card -->
            <div class="relative z-30 lg:-ml-8 transform lg:rotate-1 hover:rotate-0 transition-transform duration-300">
              <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border-2 border-indigo-200 ring-4 ring-indigo-50">
                <!-- Card Header -->
                <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-8 py-5 text-center">
                  <div class="flex items-center justify-center gap-3">
                    <i class="fas fa-check text-emerald-400 text-2xl"></i>
                    <span class="text-xl font-extrabold text-white uppercase tracking-wider">After: Custom Estimating Software</span>
                  </div>
                </div>
                <!-- Image - Much larger -->
                <div class="p-2 bg-gradient-to-b from-indigo-50 to-white">
                  <img src="https://llamapress-ai-image-uploads.s3.us-west-2.amazonaws.com/uxsgsdkjxlsss7e7cymnh93tn03x" alt="After: Custom Software" class="w-full max-w-[900px] h-auto rounded-lg shadow-inner">
                </div>
                <!-- Card Footer -->
                <div class="px-6 py-3 bg-gradient-to-r from-indigo-50 to-purple-50 border-t border-indigo-100">
                  <div class="flex items-center gap-2 text-indigo-600 text-sm font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    <span>Automated, accurate, fast</span>
                  </div>
                </div>
              </div>
              <!-- Highlight Badge -->
              <div class="absolute -top-3 -right-3 bg-gradient-to-r from-green-500 to-emerald-500 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-lg">
                62% Faster
              </div>
            </div>

          </div>
        </div>

        <div class="flex flex-wrap gap-4 justify-center mt-12">
          <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary btn-lg" %>
          <%= link_to "Read our Blog", "#recent-posts", class: "btn btn-outline btn-lg" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Features/Benefits Section -->
  <div class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-2xl bg-llama-blue/10 flex items-center justify-center text-llama-blue text-2xl mb-6">
          <i class="fas fa-chart-line"></i>
        </div>
        <h3 class="text-xl font-bold mb-3">Profitability Analysis</h3>
        <p class="text-gray-500 font-light">Understand your margins before the first shovel hits the ground.</p>
      </div>
      
      <div class="flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-2xl bg-llama-purple/10 flex items-center justify-center text-llama-purple text-2xl mb-6">
          <i class="fas fa-layer-group"></i>
        </div>
        <h3 class="text-xl font-bold mb-3">Cost Breakdowns</h3>
        <p class="text-gray-500 font-light">Detailed templates for materials, labor, and overhead tracking.</p>
      </div>

      <div class="flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-2xl bg-llama-blue/10 flex items-center justify-center text-llama-blue text-2xl mb-6">
          <i class="fas fa-shield-halved"></i>
        </div>
        <h3 class="text-xl font-bold mb-3">Risk Mitigation</h3>
        <p class="text-gray-500 font-light">Identify potential budget overruns early with our proven system.</p>
      </div>
    </div>
  </div>

  <!-- Recent Posts Section -->
  <div id="recent-posts" class="py-24 bg-base-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h2 class="text-4xl font-black text-llama-dark">Recent Insights</h2>
          <p class="text-gray-500 mt-2 font-light">The latest from our construction estimating experts.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @posts.each do |slug| %>
          <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow border">
            <div class="card-body">
              <h2 class="card-title text-2xl"><%= slug.titleize %></h2>
              <p class="text-gray-500 font-light my-4">Learn about <%= slug.gsub("-", " ") %> and how it impacts your next big bid.</p>
              <div class="card-actions justify-end">
                <%= link_to static_page_path(slug: slug), class: "btn btn-ghost btn-sm gap-2 text-llama-blue" do %>
                  Read More <i class="fas fa-arrow-right"></i>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

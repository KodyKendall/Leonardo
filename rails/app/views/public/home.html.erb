<% content_for :title, "Steel Estimating AI | AI Construction Steel Takeoff & Estimating Software" %>

<div class="bg-base-100 min-h-screen">
  <!-- Hero Section -->
  <div class="hero min-h-[70vh] bg-base-200">
    <div class="hero-content text-center">
      <div class="max-w-2xl">
        <h2 class="text-xl md:text-2xl font-bold text-llama-blue mb-2">
          AI construction steel takeoff & estimating software
        </h2>
        <h1 class="text-5xl md:text-7xl font-black text-llama-dark mb-6 leading-tight">
          Save time & bid <span class="text-llama-blue">6x more jobs</span>
        </h1>
        <p class="py-4 text-xl text-gray-600 mb-8 font-light">
          Steel Estimating AI is your go-to takeoff and estimating software, automating takeoffs with AI and a human-in-the-loop QA process, delivering quantities to your inbox within 36 hours*. Get instant excel-based estimates with clear material and labor costs.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary btn-lg" %>
          <%= link_to "Read our Blog", "#recent-posts", class: "btn btn-outline btn-lg" %>
        </div>
      </div>
    </div>
  </div>

  <!-- Features/Benefits Section -->
  <div class="py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-2xl bg-llama-blue/10 flex items-center justify-center text-llama-blue text-2xl mb-6">
          <i class="fas fa-chart-line"></i>
        </div>
        <h3 class="text-xl font-bold mb-3">Profitability Analysis</h3>
        <p class="text-gray-500 font-light">Understand your margins before the first shovel hits the ground.</p>
      </div>
      
      <div class="flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-2xl bg-llama-purple/10 flex items-center justify-center text-llama-purple text-2xl mb-6">
          <i class="fas fa-layer-group"></i>
        </div>
        <h3 class="text-xl font-bold mb-3">Cost Breakdowns</h3>
        <p class="text-gray-500 font-light">Detailed templates for materials, labor, and overhead tracking.</p>
      </div>

      <div class="flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-2xl bg-llama-blue/10 flex items-center justify-center text-llama-blue text-2xl mb-6">
          <i class="fas fa-shield-halved"></i>
        </div>
        <h3 class="text-xl font-bold mb-3">Risk Mitigation</h3>
        <p class="text-gray-500 font-light">Identify potential budget overruns early with our proven system.</p>
      </div>
    </div>
  </div>

  <!-- Recent Posts Section -->
  <div id="recent-posts" class="py-24 bg-base-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h2 class="text-4xl font-black text-llama-dark">Recent Insights</h2>
          <p class="text-gray-500 mt-2 font-light">The latest from our construction estimating experts.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @posts.each do |slug| %>
          <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow border">
            <div class="card-body">
              <h2 class="card-title text-2xl"><%= slug.titleize %></h2>
              <p class="text-gray-500 font-light my-4">Learn about <%= slug.gsub("-", " ") %> and how it impacts your next big bid.</p>
              <div class="card-actions justify-end">
                <%= link_to static_page_path(slug: slug), class: "btn btn-ghost btn-sm gap-2 text-llama-blue" do %>
                  Read More <i class="fas fa-arrow-right"></i>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

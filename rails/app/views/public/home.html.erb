<% content_for :full_width, true %>

<div class="min-h-screen bg-base-200">
  <!-- Navbar -->
  <div class="navbar bg-base-100 shadow-lg px-4 sm:px-8">
    <div class="flex-1">
      <a class="btn btn-ghost text-xl font-bold gap-2">
        <i class="fas fa-rocket text-primary"></i>
        LlamaPress
      </a>
    </div>
    <div class="flex-none hidden lg:block">
      <ul class="menu menu-horizontal px-1 font-medium">
        <li><a>Features</a></li>
        <li><a>Pricing</a></li>
        <li><a>About</a></li>
      </ul>
    </div>
    <div class="flex-none gap-2 px-2">
      <a class="btn btn-primary btn-sm sm:btn-md">Get Started</a>
    </div>
  </div>

  <!-- Hero Section -->
  <div class="hero min-h-[70vh] bg-base-100">
    <div class="hero-content text-center">
      <div class="max-w-2xl">
        <h1 class="text-5xl md:text-7xl font-black tracking-tight mb-8">
          Build Faster with <span class="text-primary">LlamaPress</span>
        </h1>
        <p class="py-6 text-xl text-base-content/70 leading-relaxed">
          The ultimate Rails starter kit powered by Daisy UI and Tailwind CSS. 
          Launch your next big idea in minutes, not months.
        </p>
        <div class="flex flex-wrap justify-center gap-4 mt-8">
          <button class="btn btn-primary btn-lg shadow-xl">
            <i class="fas fa-bolt"></i>
            Deploy Now
          </button>
          <button class="btn btn-outline btn-lg">
            View Components
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Section -->
  <div class="py-24 px-4 sm:px-8 bg-base-200">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Everything you need</h2>
        <p class="text-base-content/60">Powerful features to scale your application</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all border border-base-300">
          <div class="card-body items-center text-center">
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-4">
              <i class="fas fa-paint-brush text-2xl text-primary"></i>
            </div>
            <h2 class="card-title">Daisy UI & Tailwind</h2>
            <p class="text-base-content/70">Beautiful, responsive components out of the box. No custom CSS required.</p>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all border border-base-300">
          <div class="card-body items-center text-center">
            <div class="w-16 h-16 bg-secondary/10 rounded-2xl flex items-center justify-center mb-4">
              <i class="fas fa-shield-alt text-2xl text-secondary"></i>
            </div>
            <h2 class="card-title">Secure by Default</h2>
            <p class="text-base-content/70">Pre-configured with Devise, CSRF protection, and security best practices.</p>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all border border-base-300">
          <div class="card-body items-center text-center">
            <div class="w-16 h-16 bg-accent/10 rounded-2xl flex items-center justify-center mb-4">
              <i class="fas fa-zap text-2xl text-accent"></i>
            </div>
            <h2 class="card-title">Turbo Powered</h2>
            <p class="text-base-content/70">Ultra-fast page loads and real-time updates with Hotwire and Turbo Streams.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer p-10 bg-neutral text-neutral-content">
    <nav>
      <h6 class="footer-title">Services</h6> 
      <a class="link link-hover">Branding</a>
      <a class="link link-hover">Design</a>
      <a class="link link-hover">Marketing</a>
      <a class="link link-hover">Advertisement</a>
    </nav> 
    <nav>
      <h6 class="footer-title">Company</h6> 
      <a class="link link-hover">About us</a>
      <a class="link link-hover">Contact</a>
      <a class="link link-hover">Jobs</a>
      <a class="link link-hover">Press kit</a>
    </nav> 
    <nav>
      <h6 class="footer-title">Legal</h6> 
      <a class="link link-hover">Terms of use</a>
      <a class="link link-hover">Privacy policy</a>
      <a class="link link-hover">Cookie policy</a>
    </nav>
  </footer>
  <footer class="footer px-10 py-4 border-t bg-neutral text-neutral-content border-base-300">
    <aside class="items-center grid-flow-col">
      <i class="fas fa-rocket text-2xl"></i>
      <p>LlamaPress Industries Ltd. <br/>Providing reliable tech since 2024</p>
    </aside> 
    <nav class="md:place-self-center md:justify-self-end">
      <div class="grid grid-flow-col gap-4">
        <a><i class="fab fa-twitter text-xl"></i></a>
        <a><i class="fab fa-youtube text-xl"></i></a>
        <a><i class="fab fa-facebook text-xl"></i></a>
      </div>
    </nav>
  </footer>
</div>

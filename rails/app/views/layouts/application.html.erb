<!DOCTYPE html>
<html data-theme="light">
  <head>
    <title><%= content_for(:title) || "Steel Estimating AI | AI Construction Steel Takeoff" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <!-- Prevent caching to ensure fresh request_path and view_path -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <!-- html2canvas for screenshot capture + Fabric.js for annotation -->
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>

    <%= render 'layouts/llamapress_page_context' %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="https://llamapress-ai-image-uploads.s3.us-west-2.amazonaws.com/uj1j3g2ffgcifri2qiq591u00tvy" type="image/png">
    <link rel="apple-touch-icon" href="https://llamapress-ai-image-uploads.s3.us-west-2.amazonaws.com/uj1j3g2ffgcifri2qiq591u00tvy">
    <!-- Tailwind CSS v3 + DaisyUI v4 (compatible versions) -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,aspect-ratio,line-clamp"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.10/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'brand-purple': '#4C3F6D',
              'brand-blue': '#489DF9',
              'brand-dark': '#2D2442',
              'brand-gradient-start': '#4C3F6D',
              'brand-gradient-end': '#6d5da1',
              'accent-purple': '#8b5cf6',
            },
            backgroundImage: {
              'brand-gradient': 'linear-gradient(135deg, #4C3F6D 0%, #6d5da1 100%)',
              'text-gradient': 'linear-gradient(90deg, #4C3F6D 0%, #8b5cf6 100%)',
            },
            borderRadius: {
              '3xl': '1.5rem',
              '4xl': '2rem',
              '5xl': '3rem',
            },
            animation: {
              'shimmer': 'shimmer 2s ease-in-out infinite',
              'slide': 'slide 2s ease-in-out infinite',
              'pulse-glow': 'pulse-glow 2s ease-in-out infinite',
            },
            keyframes: {
              shimmer: {
                '0%': { backgroundPosition: '200% 0' },
                '100%': { backgroundPosition: '-200% 0' },
              },
              slide: {
                '0%': { transform: 'translateX(-100%)' },
                '100%': { transform: 'translateX(100%)' },
              },
              'pulse-glow': {
                '0%, 100%': { boxShadow: '0 0 0 0 rgba(168,85,247,0.4)' },
                '50%': { boxShadow: '0 4px 16px rgba(168,85,247,0.4)' },
              },
            },
          }
        },
        daisyui: {
          themes: [
            {
              light: {
                "primary": "#4C3F6D",
                "secondary": "#489DF9",
                "accent": "#8b5cf6",
                "neutral": "#2D2442",
                "base-100": "#ffffff",
                "--rounded-box": "1.5rem",
                "--rounded-btn": "9999px",
              },
            },
          ],
        },
      }
    </script>
    <style type="text/tailwindcss">
      @layer components {
        .glass-dark {
          @apply bg-white/5 border border-white/10 backdrop-blur-md;
        }
        .founding-pilot {
          @apply bg-[#2D2442] text-white overflow-hidden;
        }
        .btn-brand, .btn-primary {
          @apply bg-brand-gradient text-white border-none hover:shadow-lg hover:shadow-brand-purple/50 transition-all rounded-full px-8 py-3 font-bold;
        }
        .btn-secondary {
          @apply bg-brand-blue text-white border-none hover:shadow-lg hover:shadow-brand-blue/50 transition-all rounded-full px-8 py-3 font-bold;
        }
        .text-brand-gradient {
          @apply bg-text-gradient bg-clip-text text-transparent;
        }
        .badge-brand {
          @apply px-4 py-1.5 rounded-full text-[10px] font-extrabold uppercase tracking-widest bg-brand-gradient text-white border-none;
        }
        .card {
          @apply rounded-4xl bg-white border border-gray-100 shadow-sm transition-all duration-300 hover:shadow-2xl hover:shadow-brand-purple/5;
        }
        .ai-shimmer {
          background: linear-gradient(90deg, 
            rgba(255,255,255,0.12) 0%,
            rgba(139,92,246,0.6) 50%,
            rgba(255,255,255,0.12) 100%
          );
          background-size: 200% 100%;
          background-clip: text;
          -webkit-text-fill-color: transparent;
          @apply animate-shimmer;
        }
        .ai-pulse-glow {
          @apply animate-pulse-glow;
        }
      }
    </style>

    <!-- Font Awesome (public CDN) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" data-llama-id="6" data-llama-editable="true">

    <%# stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>function initApollo(){var n=Math.random().toString(36).substring(7),o=document.createElement("script");
      o.src="https://assets.apollo.io/micro/website-tracker/tracker.iife.js?nocache="+n,o.async=!0,o.defer=!0,
      o.onload=function(){window.trackingFunctions.onLoad({appId:"69aecb683afda200197a991d"})},
      document.head.appendChild(o)}initApollo();</script>

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "w4l8bv3etv");
    </script>
  </head>

  <body class="h-full min-h-screen flex flex-col">
    <% if content_for?(:hero_section) %>
      <%= yield :hero_section %>
    <% else %>
      <% unless content_for?(:hide_navbar) %>
        <%= render 'shared/navbar' %>
      <% end %>
    <% end %>

    <div class="flex-grow <%= content_for?(:full_width) ? '' : 'py-10' %>">
      <%# Flash Messages (DaisyUI Alerts) %>
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <% flash.each do |key, value| %>
          <div class="alert mb-4 shadow-lg <%= key == 'alert' ? 'alert-error' : 'alert-success' %>">
            <% if key == 'alert' %>
              <i class="fas fa-exclamation-circle"></i>
            <% else %>
              <i class="fas fa-check-circle"></i>
            <% end %>
            <span><%= value %></span>
          </div>
        <% end %>
      </div>

      <% unless content_for?(:hide_header) %>
        <header>
          <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mb-8">
            <h1 class="text-4xl font-black leading-tight tracking-tight text-brand-dark">
              <%= content_for(:header) %>
            </h1>
          </div>
        </header>
      <% end %>

      <main>
        <% if content_for?(:full_width) %>
          <%= content_for?(:content) ? yield(:content) : yield %>
        <% else %>
          <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <%= content_for?(:content) ? yield(:content) : yield %>
          </div>
        <% end %>
      </main>
    </div>

    <% unless content_for?(:hide_footer) %>
      <%= render 'shared/footer' %>
    <% end %>
  </body>
</html>
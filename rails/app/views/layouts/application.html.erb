<!DOCTYPE html>
<html data-theme="light">
  <head>
    <title><%= content_for(:title) || "Rails Basic" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <!-- Prevent caching to ensure fresh request_path and view_path -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <!-- html2canvas for screenshot capture + Fabric.js for annotation -->
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>

    <%= render 'layouts/llamapress_page_context' %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="https://service-jobs-images.s3.us-east-2.amazonaws.com/7rl98t1weu387r43il97h6ipk1l7" type="image/png">
    <link rel="apple-touch-icon" href="https://service-jobs-images.s3.us-east-2.amazonaws.com/7rl98t1weu387r43il97h6ipk1l7">
    <!-- Tailwind CSS v3 + DaisyUI v4 (compatible versions) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.10/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'llama-purple': '#4C3F6D',
              'llama-blue': '#489DF9',
              'llama-dark': '#2D2442',
            }
          }
        }
      }
    </script>

    <!-- Font Awesome (public CDN) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" data-llama-id="6" data-llama-editable="true">

    <%# stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full min-h-screen flex flex-col">
    <% unless content_for?(:hide_navbar) %>
      <%= render 'shared/navbar' %>
    <% end %>

    <div class="flex-grow <%= content_for?(:full_width) ? '' : 'py-10' %>">
      <%# Flash Messages (DaisyUI Alerts) %>
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <% flash.each do |key, value| %>
          <div class="alert mb-4 shadow-lg <%= key == 'alert' ? 'alert-error' : 'alert-success' %>">
            <% if key == 'alert' %>
              <i class="fas fa-exclamation-circle"></i>
            <% else %>
              <i class="fas fa-check-circle"></i>
            <% end %>
            <span><%= value %></span>
          </div>
        <% end %>
      </div>

      <% unless content_for?(:hide_header) %>
        <header>
          <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mb-8">
            <h1 class="text-4xl font-black leading-tight tracking-tight text-llama-dark">
              <%= content_for(:header) %>
            </h1>
          </div>
        </header>
      <% end %>

      <main>
        <% if content_for?(:full_width) %>
          <%= yield %>
        <% else %>
          <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <%= yield %>
          </div>
        <% end %>
      </main>
    </div>

    <% unless content_for?(:hide_footer) %>
      <%= render 'shared/footer' %>
    <% end %>
  </body>
</html>
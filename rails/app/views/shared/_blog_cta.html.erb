<div id="contact" class="bg-gray-50 py-20 px-8 sm:px-12 lg:px-24 rounded-[3rem] my-20 border border-gray-100 shadow-sm text-center relative overflow-hidden group transition-all hover:shadow-2xl hover:shadow-brand-purple/5">
  <div class="absolute -top-12 -right-12 w-64 h-64 bg-brand-purple/5 rounded-full blur-3xl pointer-events-none group-hover:bg-brand-purple/10 transition-colors"></div>
  
  <div class="relative z-10">
    <div class="badge-brand mb-6">Expert Help Available</div>
    <h2 class="text-4xl md:text-5xl font-black text-brand-purple mb-6 tracking-tight">
      Kill the Spreadsheet. Build an Engine.
    </h2>
    <p class="text-xl text-gray-500 mb-10 max-w-2xl mx-auto font-light leading-relaxed">
      Stop struggling with version control, broken formulas, and key-man risk. 
      Let us convert your existing Excel workflows into a custom, scalable estimating engine built exactly how your team works.
    </p>
    
    <div class="mt-12 bg-white/40 backdrop-blur-sm p-8 md:p-12 rounded-2xl border border-white/50 shadow-inner">
      <%= render partial: 'contact_submissions/form', locals: { contact_submission: ContactSubmission.new } %>
    </div>
  </div>
</div>
